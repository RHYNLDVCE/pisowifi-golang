# PisoWifi Environment Variables
# IMPORTANT: Keep this file secret. Do not commit to git.

SECRET_KEY=change_this_to_a_long_random_secret_key_before_deploying
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Network Interfaces — MUST match your hardware (run `ip link show` to confirm)
# LAN_INTERFACE = the interface clients connect to (WiFi/USB adapter side)
# WAN_INTERFACE = the interface with internet access (Starlink/ISP side)
LAN_INTERFACE=enx00e04c68042c
WAN_INTERFACE=end0